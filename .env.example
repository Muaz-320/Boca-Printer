# Boca Print – React app
# Copy to .env and set values as needed.

# Order shown on the demo order detail page (optional)
# VITE_ORDER_ID=SP261773127925108
# VITE_ORDER_NUMBER=

# Auth code for PrintTicket API (required for print)
VITE_BOCA_AUTH_CODE=d063d05b-fbb1-4bf0-b4d8-b2f603454858

# PrintTicket API: use proxy to avoid CORS
# Dev (Vite proxy): use relative URL so Vite forwards to the external API
VITE_BOCA_PRINT_TICKET_URL=/api/boca/BocaPrint/PrintTicket

# Production: point to your backend proxy, e.g. Laravel:
# VITE_BOCA_PRINT_TICKET_URL=https://your-app.com/boca-print/print-ticket

# Or direct API URL if the API has CORS enabled (no proxy):
# VITE_BOCA_API_BASE_URL=https://dynamicpricing-api.dynamicpricingbuilder.com

# Local print service for USB (default 9090)
VITE_BOCA_LOCAL_PRINT_URL=http://localhost:9090/print
